machine:
  type: worker
  sysfs:
    block.sda.queue.scheduler: mq-deadline
  network:
    interfaces:
      - deviceSelector:
          hardwareAddr: bc:24:11:b0:17:db
        dhcp: false
        mtu: 9000
        addresses:
          - 192.168.7.24/24
        routes:
          - network: 0.0.0.0/0
            gateway: 192.168.7.1
          - network: 192.168.0.0/16
            gateway: 192.168.7.1
---
apiVersion: v1alpha1
kind: HostnameConfig
auto: "off"
hostname: talos4.vaderrp.com
---
apiVersion: v1alpha1
kind: UserVolumeConfig
name: local-storage
provisioning:
  diskSelector:
    match: '!system_disk'
  minSize: 32GB
